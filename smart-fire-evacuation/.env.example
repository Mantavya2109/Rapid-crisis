# Environment variables for Raspberry Pi Edge Controller
# ─────────────────────────────────────────────────────────────────────
# Copy:   cp .env.example .env
# Edit:   nano .env                 ← set your CLOUD_BASE_URL, secrets, etc.
# Load:   (python-dotenv loads this automatically via main.py / app.py)
# ─────────────────────────────────────────────────────────────────────

# ── Building identity ─────────────────────────────────────────────────
BUILDING_ID=BUILDING_01

# ── Flask REST API server ─────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
DEBUG=false

# ── Fire detection thresholds ─────────────────────────────────────────
TEMP_THRESHOLD=40.0         # °C   — LED turns YELLOW/RED if exceeded
SMOKE_THRESHOLD=200.0       # ppm  — LED turns RED if exceeded

# ── Alert debounce ────────────────────────────────────────────────────
ALERT_DEBOUNCE_SEC=5        # seconds before the same node can re-alert

# ── Device heartbeat ──────────────────────────────────────────────────
HEARTBEAT_TIMEOUT_SEC=30    # seconds before device marked OFFLINE

# ── SQLite persistence (SD-card wear protection) ──────────────────────
DB_FLUSH_INTERVAL_SEC=3     # write to SQLite every N seconds (not on every sensor msg)
# DATA_DIR=/var/lib/fire-evacuation   ← override data directory if needed

# ── MQTT Broker (Mosquitto, runs locally on the Pi) ───────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=rpi-edge-controller
MQTT_QOS=1
MQTT_KEEPALIVE_SEC=60
# Credentials (leave blank if allow_anonymous true in mosquitto.conf)
MQTT_USERNAME=
MQTT_PASSWORD=

# Topic wildcards the Pi subscribes to:
#   sensors/data/+       → telemetry from all ESP32 nodes
#   sensors/heartbeat/+  → keepalive pings from all ESP32 nodes
MQTT_TOPIC_SENSOR=sensors/data/+
MQTT_TOPIC_HEARTBEAT=sensors/heartbeat/+

# ── WS2812B LED Strip (rpi_ws281x — direct GPIO on Pi) ───────────────
# GPIO 18 is the default PWM pin used by rpi_ws281x.
# LED_COUNT  = total physical LEDs on the strip.
# Per-node zones are auto-partitioned if zone_config.json doesn't exist.
LED_GPIO_PIN=18
LED_COUNT=60
LED_FREQ_HZ=800000
LED_DMA=5
LED_BRIGHTNESS=128          # 0 (off) to 255 (maximum brightness)
LED_INVERT=false            # true only if using a level-shifter that inverts signal
LED_CHANNEL=0               # 0 for GPIO 18; 1 for GPIO 13

# ── LED zone config file ──────────────────────────────────────────────
# JSON file mapping nodeIds → LED ranges: {"ROOM_101": [0, 9], ...}
# If absent, zones are auto-partitioned from the building graph.
# ZONE_CONFIG_PATH=/home/pi/smart-fire-evacuation/config/zone_config.json

# ── Hazard model (Dijkstra path weights) ──────────────────────────────
HAZARD_DECAY_FACTOR=0.5
NEIGHBOR_HAZARD_SPREAD=0.3

# ── API Security ──────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable auth (dev/test mode only).
API_SECRET_KEY=
REPLAY_WINDOW_SEC=30

# ── Rate limiting ─────────────────────────────────────────────────────
RATELIMIT_STORAGE_URI=memory://
#   sqlite:////home/pi/data/rate.db  ← Pi-native persistent rate limits
#   redis://localhost:6379           ← production Redis
RATE_LIMIT_SENSOR=60 per minute
RATE_LIMIT_EVACUATE=10 per minute
RATE_LIMIT_DEFAULT=30 per minute

# ── Cloud backend ─────────────────────────────────────────────────────
CLOUD_BASE_URL=https://your-cloud-backend.com
CLOUD_API_KEY=your-bearer-token-here
CLOUD_TIMEOUT_SEC=5
CLOUD_RETRY_ATTEMPTS=3
# Specific endpoint overrides (defaults are derived from CLOUD_BASE_URL):
# CLOUD_FIRE_ALERT_URL=https://your-cloud-backend.com/fire-alert
# CLOUD_LED_BATCH_URL=https://your-cloud-backend.com/led/batch
# CLOUD_REGISTER_URL=https://your-cloud-backend.com/devices/register
# CLOUD_TELEMETRY_URL=https://your-cloud-backend.com/telemetry

# ── ESP32 Fail-Safe ───────────────────────────────────────────────────
# Milliseconds after which an ESP32 that has received NO heartbeat ACK
# from the Pi should enter visual fail-safe mode (blink onboard LED RED).
# Returned in every /heartbeat response so firmware can self-adjust.
ESP32_FAILSAFE_BLINK_MS=60000

# ─────────────────────────────────────────────────────────────────────
# MQTT QUICK TEST (run from another terminal after setup):
# ─────────────────────────────────────────────────────────────────────
# Normal reading:
#   mosquitto_pub -t sensors/data/ROOM_101 \
#     -m '{"deviceId":"ESP32_A","temperature":25,"smoke":100,"status":"OK"}'
#
# Warning reading:
#   mosquitto_pub -t sensors/data/ROOM_101 \
#     -m '{"deviceId":"ESP32_A","temperature":42,"smoke":100,"status":"WARNING"}'
#
# Danger reading:
#   mosquitto_pub -t sensors/data/ROOM_101 \
#     -m '{"deviceId":"ESP32_A","temperature":55,"smoke":350,"status":"FIRE"}'
#
# Heartbeat:
#   mosquitto_pub -t sensors/heartbeat/ROOM_101 \
#     -m '{"deviceId":"ESP32_A"}'



