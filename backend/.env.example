# ─────────────────────────────────────────────────────────────────────
# Rapid Crisis — Cloud Backend (Node.js/Express) — .env template
# ─────────────────────────────────────────────────────────────────────
# Copy:    cp .env.example .env
# Windows: copy .env.example .env
# Then fill in the values below.
#
# Notes:
# - Firebase is used for building graphs + telemetry persistence.
# - If Firebase vars are missing, the server still starts but DB features
#   will be unavailable (server logs: "Firebase not ready").
# ─────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────
PORT=3000

# Optional: if set, write routes (POST/PUT/DELETE) require this key.
# Clients can send it as:
#   - X-API-Key: <API_KEY>
#   - Authorization: Bearer <API_KEY>
API_KEY=

# Optional CORS allowlist entry (production)
FRONTEND_URL=http://localhost:5173

# ── Firebase Admin (Firestore) ───────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=

# IMPORTANT:
# - Keep the \n escaping (Firebase private keys are multi-line)
# - Wrap the value in quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# ── Optional: Cloudinary (floorplan image upload from editor) ─────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Optional: Gemini (AI incident text analysis) ─────────────────────
GEMINI_API_KEY=

# ── Optional: push graph updates to the Raspberry Pi after deploy ─────
# When set, POST /building/setup will also POST to: ${PI_BASE_URL}/graph/update
PI_BASE_URL=

