# ─────────────────────────────────────────────────────────────────────
# Smart Fire Evacuation — Backend Environment Configuration
# ─────────────────────────────────────────────────────────────────────
# Copy: cp .env.example .env
# Edit: fill in your Firebase service account path
# ─────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────
PORT=3000

# ── Firebase Service Account ─────────────────────────────────────────
# Option A: Place serviceAccountKey.json in backend/config/ (default)
# Option B: Set this path to wherever your key file lives
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# ─────────────────────────────────────────────────────────────────────
# Raspberry Pi Connection Notes:
# ─────────────────────────────────────────────────────────────────────
# In your Raspberry Pi .env, set:
#   CLOUD_BASE_URL=http://<your-backend-host>:3000
#
# The Pi's cloud_sync.py will then automatically POST to:
#   POST http://<backend>:3000/fire-alert   → fire events + hazard weights
#   POST http://<backend>:3000/telemetry   → filtered sensor readings
# ─────────────────────────────────────────────────────────────────────
