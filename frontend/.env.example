# Rapid Crisis — Frontend (React/Vite) — .env template
# Copy:    cp .env.example .env
# Windows: copy .env.example .env

# Cloud backend base URL
VITE_API_URL=http://localhost:3000

# Optional: only needed if backend API_KEY is set.
# Leave empty when running backend in dev mode (API_KEY not configured).
VITE_API_KEY=
